# ============================================
# REQUIRED API KEYS
# ============================================

# Cohere API Key (FREE: 100,000 calls/month)
# Get from: https://cohere.ai
# Sign up for free account and copy your key
COHERE_API_KEY=your-cohere-api-key-here

# Google Gemini API Key (FREE tier available)
# Get from: https://makersuite.google.com/app/apikey
# Optional - only if using AI chat features
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Connection
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/mediflow

# ============================================
# OCR CONFIGURATION
# ============================================

# Enable Google Cloud Vision (optional, better accuracy but costs money)
# Default: false (uses free Tesseract OCR)
USE_GOOGLE_VISION=false

# Google Cloud Vision API Key (only if USE_GOOGLE_VISION=true)
GOOGLE_VISION_API_KEY=your-google-vision-key-here

# Tesseract OCR path (Windows users may need to set this)
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: usually just "tesseract" (in PATH)
TESSERACT_PATH=tesseract

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Directory to store uploaded medical documents
UPLOAD_DIRECTORY=./uploads/medical_docs

# ============================================
# ENVIRONMENT
# ============================================

# Development or Production
ENVIRONMENT=development
